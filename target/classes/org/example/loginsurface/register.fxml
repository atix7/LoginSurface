<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="400.0" prefWidth="360.0" style="-fx-background-color: black;"
            xmlns="http://javafx.com/javafx/19" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.loginsurface.RegisterController">

    <Label layoutX="100.0" layoutY="30.0" text="Register" textFill="#DFC46C">
        <font><Font size="28.0" /></font>
    </Label>

    <Label layoutX="40.0" layoutY="100.0" text="Name" textFill="#5fcd0b">
        <font><Font size="14.0" /></font>
    </Label>
    <TextField fx:id="nameField" layoutX="140.0" layoutY="97.0" prefWidth="170.0" promptText="Your name" />

    <Label layoutX="40.0" layoutY="140.0" text="Email" textFill="#5fcd0b">
        <font><Font size="14.0" /></font>
    </Label>
    <TextField fx:id="mailField" layoutX="140.0" layoutY="137.0" prefWidth="170.0" promptText="Your email" />

    <Label layoutX="40.0" layoutY="180.0" text="Phone" textFill="#5fcd0b">
        <font><Font size="14.0" /></font>
    </Label>
    <TextField fx:id="phoneField" layoutX="140.0" layoutY="177.0" prefWidth="170.0" promptText="Your phone" />

    <Label layoutX="40.0" layoutY="220.0" text="Password" textFill="#5fcd0b">
        <font><Font size="14.0" /></font>
    </Label>
    <PasswordField fx:id="passwordField" layoutX="140.0" layoutY="217.0" prefWidth="170.0" promptText="Password" />

    <Label layoutX="40.0" layoutY="260.0" text="Confirm pw" textFill="#5fcd0b">
        <font><Font size="14.0" /></font>
    </Label>
    <PasswordField fx:id="passwordField2" layoutX="140.0" layoutY="257.0" prefWidth="170.0" promptText="Retype password" />

    <Label fx:id="statusLabel" layoutX="40.0" layoutY="300.0" prefWidth="280.0" textFill="#e74c3c">
        <font><Font size="13.0" /></font>
    </Label>

    <Button fx:id="registerButton" layoutX="80.0" layoutY="335.0" prefHeight="35.0" prefWidth="130.0"
            mnemonicParsing="false" onAction="#onRegister"
            style="-fx-background-color: #DFC46C; -fx-font-size: 14;" text="Register" />

    <Button layoutX="220.0" layoutY="335.0" prefHeight="35.0" prefWidth="90.0"
            mnemonicParsing="false" onAction="#onBack"
            style="-fx-background-color: #444; -fx-text-fill: white; -fx-font-size: 13;" text="Back" />

</AnchorPane>